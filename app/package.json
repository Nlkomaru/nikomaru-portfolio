        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^5.0.4",
        "autoprefixer": "^10.4.27",
        "jsdom": "^27.0.0",
        "typescript": "^5.7.2",
        "vite": "^7.1.7",
        "vitest": "^3.0.5",
        "wrangler": "^4.66.0"
