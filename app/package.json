{
    "name": "@nikomaru-portfolio/app",
    "private": true,
    "type": "module",
    "scripts": {
        "prepare": "panda codegen",
        "dev": "vite dev --port 3000 --host --open",
        "build": "vite build",
        "panda:codegen": "panda codegen",
        "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
